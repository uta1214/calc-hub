{
  "name": "calchub",
  "displayName": "CalcHub",
  "publisher": "uta-orange-1214",
  "author": {
    "name": "uta"
  },
  "description": "Sidebar calculator for VS Code — Basic, Functions, Base conversion, SI Unit conversion",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.80.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/uta1214/calc-hub"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "calc-hub-container",
          "title": "Calc Hub",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "calc-hub-container": [
        {
          "type": "webview",
          "id": "calc-hub.view",
          "name": "Calculator"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "@types/node": "^18.0.0",
    "typescript": "^5.0.0"
  },
  "license": "MIT",
  "icon": "icon.png",
  "keywords": [
    "calculator",
    "sidebar",
    "base conversion",
    "unit conversion",
    "math"
  ]
}